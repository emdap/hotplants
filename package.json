{
  "name": "smarty-plants",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tsc": "tsc -b --noEmit",
    "generate-graphql": "graphql-codegen --watch http://localhost:3000/graphql",
    "generate-graphql:prod": "graphql-codegen --watch https://hotplants-server.fly.dev/graphql",
    "generate-hotplants-types": "npx openapi-typescript http://localhost:3000/swagger.json -o src/generated/schemas/hotplants.d.ts",
    "generate-hotplants-types:prod": "npx openapi-typescript https://hotplants-server.fly.dev/swagger.json -o src/generated/schemas/hotplants.d.ts",
    "generate-nominatim-types": "npx openapi-typescript src/generated/schemas/nominatim-schema.json -o src/generated/schemas/nominatim.d.ts",
    "generate-openapi-types": "pnpm generate-hotplants-types && pnpm generate-nominatim-types && pnpm generate-gbif-types"
  },
  "dependencies": {
    "@apollo/client": "^4.0.2",
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.81.5",
    "@turf/turf": "^7.2.0",
    "classnames": "^2.5.1",
    "graphql": "^16.11.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet.markercluster": "^1.5.3",
    "lodash": "^4.17.21",
    "lottie-react": "^2.4.1",
    "motion": "^12.23.24",
    "openapi-fetch": "^0.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^3.1.1",
    "react-leaflet-draw": "^0.21.0",
    "react-router": "^7.9.5",
    "react-use": "^17.6.0",
    "rxjs": "^7.8.2",
    "wkt": "^0.1.1"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.0",
    "@eslint/js": "^9.29.0",
    "@flydotio/dockerfile": "^0.7.10",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/schema-ast": "^4.1.0",
    "@graphql-codegen/typescript-apollo-client-helpers": "^3.0.1",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@parcel/watcher": "^2.5.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/lodash": "^4.17.20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "openapi-typescript": "^7.8.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
